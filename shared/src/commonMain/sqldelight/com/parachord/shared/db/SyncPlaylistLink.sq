CREATE TABLE IF NOT EXISTS sync_playlist_link (
    localPlaylistId TEXT NOT NULL,
    providerId      TEXT NOT NULL,
    externalId      TEXT NOT NULL,
    snapshotId      TEXT,
    pendingAction   TEXT,
    syncedAt        INTEGER NOT NULL,
    PRIMARY KEY (localPlaylistId, providerId)
);

selectAll:
SELECT * FROM sync_playlist_link;

selectForLocal:
SELECT * FROM sync_playlist_link WHERE localPlaylistId = ?;

selectForLink:
SELECT * FROM sync_playlist_link WHERE localPlaylistId = ? AND providerId = ?;

selectByExternalId:
SELECT * FROM sync_playlist_link WHERE providerId = ? AND externalId = ?;

selectForProvider:
SELECT * FROM sync_playlist_link WHERE providerId = ?;

upsert:
INSERT OR REPLACE INTO sync_playlist_link (localPlaylistId, providerId, externalId, syncedAt)
VALUES (?, ?, ?, ?);

upsertWithSnapshot:
INSERT OR REPLACE INTO sync_playlist_link (localPlaylistId, providerId, externalId, snapshotId, syncedAt)
VALUES (?, ?, ?, ?, ?);

deleteForLink:
DELETE FROM sync_playlist_link WHERE localPlaylistId = ? AND providerId = ?;

deleteByExternalId:
DELETE FROM sync_playlist_link WHERE providerId = ? AND externalId = ?;

deleteForLocal:
DELETE FROM sync_playlist_link WHERE localPlaylistId = ?;

deleteForProvider:
DELETE FROM sync_playlist_link WHERE providerId = ?;

setPendingAction:
UPDATE sync_playlist_link
SET pendingAction = :pendingAction
WHERE localPlaylistId = :localPlaylistId AND providerId = :providerId;

clearPendingAction:
UPDATE sync_playlist_link SET pendingAction = NULL WHERE localPlaylistId = ? AND providerId = ?;

-- One-time cleanup: the N-way swap deleted the NWAY_FILL_PENDING_ACTION="nway-fill"
-- writer, but stale 'nway-fill' values linger on real installs and the legacy push
-- skips any non-null pendingAction. Idempotent (0 rows after the first run).
clearNwayFillPendingActions:
UPDATE sync_playlist_link SET pendingAction = NULL WHERE pendingAction = 'nway-fill';

selectPendingForProvider:
SELECT * FROM sync_playlist_link WHERE providerId = ? AND pendingAction IS NOT NULL;

-- Multi-provider propagation predicates (Phase 3). Used by the four
-- cooperating fixes from desktop CLAUDE.md: pull paths flag locallyModified
-- when other mirrors exist; post-push clear iterates the source-excluding
-- subset of mirrors.

countOtherMirrors:
SELECT COUNT(*) FROM sync_playlist_link
WHERE localPlaylistId = :localPlaylistId AND providerId != :excludeProviderId;

selectMirrorsExcluding:
SELECT * FROM sync_playlist_link
WHERE localPlaylistId = :localPlaylistId AND providerId != :excludeProviderId;
