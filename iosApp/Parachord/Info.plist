<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Parachord</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!--
	  Required before MusicKit's MusicAuthorization.request() can show
	  the Apple Music access prompt. Safe to ship without the MusicKit
	  *entitlement* — reading MusicAuthorization.currentStatus works
	  with just this string; actually requesting access + playing
	  catalog tracks additionally needs the MusicKit capability enabled
	  on the App ID (Xcode → Signing & Capabilities → + → MusicKit) and
	  an Apple Music subscription on the device.
	-->
	<key>NSAppleMusicUsageDescription</key>
	<string>Parachord uses Apple Music to play tracks resolved to the Apple Music catalog.</string>
	<!--
	  Schemes Parachord queries via `UIApplication.canOpenURL`. iOS
	  returns false for any unlisted scheme regardless of whether the
	  target app is installed, so the Spotify Connect wake-detection
	  (phase 4.8) needs `spotify` declared here.
	-->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>spotify</string>
	</array>
	<!--
	  Spotify OAuth (PKCE) client id, read by IosContainer via
	  NSBundle.objectForInfoDictionaryKey("SpotifyClientID"). PKCE public
	  client ids are not secret (they appear in the authorize URL), so this
	  is safe to commit. ⚠️ FILL IN with the Parachord Spotify app's client
	  id (same one Android uses — SPOTIFY_CLIENT_ID in local.properties) and
	  register the redirect URI `parachord://auth/callback/spotify` in that
	  Spotify app's dashboard. Empty = Spotify auth is inert (Connect button
	  errors with "invalid client").
	-->
	<key>SpotifyClientID</key>
	<string></string>
	<!--
	  UIBackgroundModes: `audio` keeps AVPlayer / MusicKit / Spotify
	  Connect playback alive when the app is backgrounded or the screen
	  is locked. Without it, iOS suspends the process on background and
	  audio stops. This is the load-bearing reason this Info.plist
	  exists as a real file (the INFOPLIST_KEY_* build-setting mechanism
	  doesn't expose UIBackgroundModes — it's not in Xcode's
	  synthesizable allowlist).
	-->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
