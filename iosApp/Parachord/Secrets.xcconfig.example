// Copy to `Secrets.xcconfig` (gitignored) and fill in the built-in app keys.
// Get a Last.fm API account: https://www.last.fm/api/account/create
LASTFM_API_KEY =
LASTFM_SHARED_SECRET =

// Apple Music developer token (JWT) for catalog artist images. Optional.
APPLE_MUSIC_DEVELOPER_TOKEN =

// Achordion bearer token — pre-warms Achordion's track-links cache on scrobble
// + share (#215). Same shared app token as Android local.properties
// ACHORDION_BEARER_TOKEN. Optional: blank = submit short-circuits inertly.
ACHORDION_BEARER_TOKEN =
